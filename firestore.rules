rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBudgetMember(budgetId) {
      return isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/budgets/$(budgetId)).data.memberIds;
    }

    function isBudgetAdmin(budgetId) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/budgets/$(budgetId)).data.members[request.auth.uid].role == "admin";
    }

    // ── Users: only the owner can read/write their own profile ────────
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      match /favorites/{favoriteId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ── Budgets ───────────────────────────────────────────────────────
    match /budgets/{budgetId} {
      // Any authenticated user can read/update (needed for join-via-invitation flow)
      // For v1 this is acceptable; production would use a Cloud Function callable
      allow read:    if isAuthenticated();
      allow create:  if isAuthenticated();
      allow update:  if isAuthenticated();
      allow delete: if isBudgetAdmin(budgetId);

      // Categories subcollection
      match /categories/{categoryId} {
        allow read:  if isBudgetMember(budgetId);
        allow write: if isBudgetAdmin(budgetId);
      }

      // Fixed costs subcollection
      match /fixedCosts/{fixedCostId} {
        allow read:  if isBudgetMember(budgetId);
        allow write: if isBudgetAdmin(budgetId);
      }

      // Yearly goals subcollection
      match /yearlyGoals/{yearlyGoalId} {
        allow read:  if isBudgetMember(budgetId);
        allow write: if isBudgetAdmin(budgetId);
      }

      // Items subcollection
      match /items/{itemId} {
        allow read:  if isBudgetMember(budgetId);
        allow write: if isBudgetAdmin(budgetId);
      }

      // Months subcollection
      match /months/{monthId} {
        allow read:          if isBudgetMember(budgetId);
        allow create, update: if isBudgetAdmin(budgetId);

        // Purchases subcollection within months
        match /purchases/{purchaseId} {
          allow read:   if isBudgetMember(budgetId);
          allow create: if isBudgetMember(budgetId)
            && request.resource.data.createdBy == request.auth.uid;
          allow update, delete: if isBudgetMember(budgetId)
            && (resource.data.createdBy == request.auth.uid || isBudgetAdmin(budgetId));
        }
      }
    }

    // ── Invitations ─────────────────────────────────────────────────────
    match /invitations/{invitationId} {
      // Any authenticated user can read (needed for code validation)
      allow read: if isAuthenticated();
      // Only budget admins can create invitations
      allow create: if isAuthenticated()
        && isBudgetAdmin(request.resource.data.budgetId);
      // Authenticated users can update (redeem code: status → used)
      allow update: if isAuthenticated();
      // No deletes from client
      allow delete: if false;
    }
  }
}
